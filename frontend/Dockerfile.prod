# Прод-образ: сборка Vite → статика, раздаётся nginx.
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
# В проде фронт и API под одним доменом (Caddy маршрутизирует /api → backend),
# поэтому база API — относительный /api.
ENV VITE_API_BASE_URL=/api
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
