# Кладётся на сервер как /opt/shared-postgres/.env. В git НЕ коммитим.
# Пароли ролей должны СОВПАДАТЬ с DB_PASSWORD/POSTGRES_PASSWORD в .env окружений:
#   cvtailor_test   → /opt/cvtailor-test/.env  (DB_PASSWORD)
#   cvtailor_prod   → /opt/cvtailor-prod/.env  (DB_PASSWORD)
#   reviewlens_test → /opt/reviewlens-test/.env (POSTGRES_PASSWORD)
#   reviewlens_prod → /opt/reviewlens-prod/.env (POSTGRES_PASSWORD)

POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_super_password

CVTAILOR_PROD_DB_PASSWORD=CHANGE_ME_cvtailor_prod
CVTAILOR_TEST_DB_PASSWORD=CHANGE_ME_cvtailor_test
REVIEWLENS_PROD_DB_PASSWORD=CHANGE_ME_reviewlens_prod
REVIEWLENS_TEST_DB_PASSWORD=CHANGE_ME_reviewlens_test
