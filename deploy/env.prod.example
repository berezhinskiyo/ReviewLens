# ─────────────────────────────────────────────────────────────────────────────
# PROD-окружение ReviewLens — кладётся на сервер как /opt/reviewlens-prod/.env
# Единый файл: и compose-интерполяция (${VAR}), и конфиг backend. В git НЕ коммитим.
# Деплой (git reset --hard) его НЕ трогает (в .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Compose: файл деплоя, имя проекта (изоляция), loopback-порт для общего edge
COMPOSE_FILE=docker-compose.deploy.yml
COMPOSE_PROJECT_NAME=reviewlens-prod
WEB_PORT=18081

# Доступ к ОБЩЕМУ PostgreSQL (стек shared-postgres). База/роль этого окружения.
# POSTGRES_PASSWORD должен совпадать с REVIEWLENS_PROD_DB_PASSWORD в /opt/shared-postgres/.env
POSTGRES_USER=reviewlens_prod
POSTGRES_PASSWORD=CHANGE_ME_reviewlens_prod
POSTGRES_DB=reviewlens_prod

# JWT (свой секрет)
JWT_SECRET_KEY=CHANGE_ME_prod_jwt_secret

# LLM-роутер polza.ai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://polza.ai/api/v1
OPENAI_MODEL_EXTRACT=google/gemini-2.5-flash-lite
OPENAI_MODEL_CLUSTER=google/gemini-2.5-flash-lite
OPENAI_MODEL_SYNTH=deepseek/deepseek-v3.2

# Внешние URL (общий edge, https)
FRONTEND_URL=https://reviewlens.vniknu.ru
BACKEND_URL=https://reviewlens.vniknu.ru

# Согласие / бутстрап-админ
CONSENT_VERSION=2026-06-29
BOOTSTRAP_ADMIN_EMAIL=admin@reviewlens.ru

# Капча / OAuth (redirect URI prod-домена добавить в приложениях Яндекс/VK)
SMARTCAPTCHA_SERVER_KEY=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Email (боевой)
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@reviewlens.ru

# Эквайринг Т-Банк — БОЕВЫЕ креды из ЛК Т-Банка (НЕ демо!)
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2/
TINKOFF_TAXATION=usn_income
TINKOFF_VAT=none

# Окружение / скраперы
ENV=production
ENABLED_MARKETPLACES=wb
# Для Ozon/Яндекс/Avito нужен резидентный РФ-прокси + образ worker с Playwright
SCRAPER_PROXY=
MAX_REVIEWS_PER_ANALYSIS=500
ANALYSIS_COST_BUDGET_KOPECKS=1500
