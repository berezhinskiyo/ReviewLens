# Скопируйте в .env и заполните. .env НИКОГДА не коммитим.

# База / очередь
DATABASE_URL=postgresql+asyncpg://reviewlens:reviewlens@db:5432/reviewlens
REDIS_URL=redis://redis:6379/0

# LLM-роутер (OpenAI-совместимый). По умолчанию polza.ai; для прямого OpenAI
# оставьте OPENAI_BASE_URL пустым и используйте обычные модели (gpt-4o-mini).
OPENAI_API_KEY=pza_...
OPENAI_BASE_URL=https://polza.ai/api/v1
# Модели параметризуются, чтобы менять без передеплоя
OPENAI_MODEL_EXTRACT=google/gemini-2.5-flash-lite
OPENAI_MODEL_CLUSTER=google/gemini-2.5-flash-lite
OPENAI_MODEL_SYNTH=deepseek/deepseek-v3.2

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Регистрация / согласие
CONSENT_VERSION=2026-06-29
# Этот email при регистрации/входе автоматически получает права администратора
BOOTSTRAP_ADMIN_EMAIL=admin@reviewlens.ru

# Внешние URL (OAuth redirect + ссылка обратно во фронт)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Капча Яндекс SmartCaptcha (пусто = проверка пропускается)
SMARTCAPTCHA_SERVER_KEY=

# OAuth провайдеры
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Email с кодом. Приоритет: Postbox HTTP → SMTP → консоль (пусто всё = в логи).
# Yandex Postbox (AWS SES v2 + SigV4): ключ статического сервисного аккаунта.
EMAIL_HTTP_ENDPOINT=
EMAIL_HTTP_KEY_ID=
EMAIL_HTTP_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@reviewlens.ru

# Эквайринг Т-Банк (T-Bank / Тинькофф Касса)
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2/
TINKOFF_TAXATION=usn_income
TINKOFF_VAT=none

# Окружение
ENV=development

# Включённые маркетплейсы (через запятую). По умолчанию только WB.
# Остальные (ozon,yandex,megamarket,avito) есть в коде, но требуют
# анти-бот-источника (прокси/scraping-API) — включать при наличии.
ENABLED_MARKETPLACES=wb

# Лимиты анализов отзывов
MAX_REVIEWS_PER_ANALYSIS=500
ANALYSIS_COST_BUDGET_KOPECKS=1500

# Прокси для скраперов (Ozon/Яндекс/Avito часто требуют РФ/резидентные прокси)
# Формат: http://user:pass@host:port или socks5://host:port. Пусто = без прокси.
SCRAPER_PROXY=
